{
  "name": "@multica-console/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx --watch src/server.ts",
    "build": "tsup src/server.ts --format esm --dts",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/session": "^11.0.0",
    "@multica-console/shared": "workspace:*",
    "@sinclair/typebox": "^0.34.49",
    "connect-redis": "^8.0.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
